# ── NmapSLM Environment Configuration ────────────────────────────────────────

# ── AI Provider ──────────────────────────────────────────────────────────────
# "gemini" = Google Gemini (default, membutuhkan API key + internet)
# "slm"    = Local Ollama / QwenNmap (offline, tidak butuh API key)
DEFAULT_AI_PROVIDER=gemini

# ── Google Gemini ─────────────────────────────────────────────────────────────
# Dapatkan API key gratis di: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.0-flash

# ── Local SLM / Ollama ────────────────────────────────────────────────────────
# Jalankan: ollama pull qwen2.5:1.5b
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:1.5b

# ── Server ───────────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
DEBUG=false

# ── Scan ─────────────────────────────────────────────────────────────────────
NMAP_TIMEOUT=300
MAX_CONCURRENT_SCANS=3

# ── Reports ──────────────────────────────────────────────────────────────────
REPORTS_DIR=/tmp/nmap_slm_reports
